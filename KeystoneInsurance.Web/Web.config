<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <connectionStrings>
    <add name="KeystoneInsurance" 
         connectionString="Server=(localdb)\mssqllocaldb;Database=KeystoneInsurance;Trusted_Connection=True;" 
         providerName="System.Data.SqlClient" />
  </connectionStrings>
  
  <appSettings>
    <add key="webpages:Version" value="3.0.0.0" />
    <add key="webpages:Enabled" value="false" />
    <add key="ClientValidationEnabled" value="true" />
    <add key="UnobtrusiveJavaScriptEnabled" value="true" />
    
    <!-- Application Settings -->
    <add key="DefaultQuoteExpirationDays" value="30" />
    <add key="MaxPropertyValue" value="10000000" />
    <add key="MinimumPremium" value="500" />
    
    <!-- Integration Endpoints -->
    <add key="ReinsuranceServiceEndpoint" value="http://reinsurance-partner.example.com/service" />
    <add key="RegulatoryReportingEndpoint" value="https://naic-reporting.example.com/api" />
    
    <!-- MSMQ Configuration -->
    <add key="PolicyIssuanceQueuePath" value=".\private$\policyissuance" />
    <add key="EndorsementQueuePath" value=".\private$\endorsements" />
  </appSettings>
  
  <system.web>
    <compilation debug="true" targetFramework="4.6.1" />
    <httpRuntime targetFramework="4.6.1" />
    <authentication mode="Windows" />
    <authorization>
      <allow users="*" />
    </authorization>
  </system.web>
  
  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <dependentAssembly>
        <assemblyIdentity name="System.Web.Helpers" publicKeyToken="31bf3856ad364e35" />
        <bindingRedirect oldVersion="1.0.0.0-3.0.0.0" newVersion="3.0.0.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Web.WebPages" publicKeyToken="31bf3856ad364e35" />
        <bindingRedirect oldVersion="1.0.0.0-3.0.0.0" newVersion="3.0.0.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Web.Mvc" publicKeyToken="31bf3856ad364e35" />
        <bindingRedirect oldVersion="1.0.0.0-5.2.3.0" newVersion="5.2.3.0" />
      </dependentAssembly>
    </assemblyBinding>
  </runtime>
  
  <system.serviceModel>
    <bindings>
      <basicHttpBinding>
        <binding name="ReinsuranceServiceBinding" maxReceivedMessageSize="2147483647">
          <security mode="Transport" />
        </binding>
      </basicHttpBinding>
    </bindings>
    <client>
      <endpoint address="http://reinsurance-partner.example.com/service"
                binding="basicHttpBinding"
                bindingConfiguration="ReinsuranceServiceBinding"
                contract="KeystoneInsurance.Integration.IReinsuranceService"
                name="ReinsuranceService" />
    </client>
  </system.serviceModel>
</configuration>
